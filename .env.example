# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/subscription_db
DB_PORT=5432

# JWT
# 운영에서는 반드시 아래 명령으로 생성한 안전한 값으로 교체하세요:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — 여러 도메인은 콤마로 구분 (운영 예: https://app.subflow.app,https://subflow.app)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 운영 배포 (docker compose)
POSTGRES_PASSWORD=postgres     # 신규 배포 시 강한 값으로
WEB_PORT=3000                  # nginx 웹 컨테이너 호스트 포트

# App
DEBUG=true
# 리버스 프록시(nginx 등) 뒤에 배포할 때만 true — rate limit이 실제 클라이언트 IP를 사용
TRUST_PROXY=false

# AI 뉴스 요약 (선택) — 미설정 시 원문/폴백 유지. OpenAI gpt-4o-mini 사용
OPENAI_API_KEY=

# 이메일 발송 (선택) — 미설정 시 이메일 발송 no-op
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SubFlow <no-reply@subflow.app>
